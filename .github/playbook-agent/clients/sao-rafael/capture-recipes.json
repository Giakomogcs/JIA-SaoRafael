{
  "$schema": "Receitas declarativas para o capturador. Cada path bate com um screenshot referenciado em playbook/content.json.",
  "_securityNote": "Mascaramento agressivo: input[readonly], input[type=password], qualquer texto matching longflatworm/*.cloudfy.live, padrões de senha. NUNCA confiar só no overlay manual.",

  "sessions": {
    "cloudfy": {
      "envBase": "CLOUDFY_URL",
      "login": {
        "url": "{{CLOUDFY_URL}}",
        "steps": [
          { "fill": "input[type=email], input[name=email], input[placeholder*=mail i]", "value": "{{CLOUDFY_EMAIL}}" },
          { "fill": "input[type=password], input[name=password]", "value": "{{CLOUDFY_PASSWORD}}" },
          { "click": "button[type=submit], button:has-text('Entrar'), button:has-text('Login'), button:has-text('Sign in')" },
          { "waitSelector": "a:has-text('Serviços'), a:has-text('Services'), nav, [data-testid=services]", "timeout": 25000 }
        ]
      }
    },
    "n8n": {
      "envBase": "N8N_URL",
      "login": {
        "url": "{{N8N_URL}}",
        "steps": [
          { "fill": "input[type=email], input[name=email]", "value": "{{N8N_EMAIL}}" },
          { "fill": "input[type=password], input[name=password]", "value": "{{N8N_PASSWORD}}" },
          { "click": "button[type=submit], button:has-text('Sign in'), button:has-text('Entrar')" },
          { "waitSelector": "[data-test-id=workflows-list-container], .workflows-page, aside, nav", "timeout": 30000 }
        ]
      }
    },
    "supabase": {
      "envBase": "SUPABASE_URL",
      "login": {
        "url": "{{SUPABASE_DASHBOARD}}",
        "httpAuth": true,
        "username": "{{SUPABASE_EMAIL}}",
        "password": "{{SUPABASE_PASSWORD}}"
      }
    },
    "gcp": {
      "envBase": "GCP_LOGIN_URL",
      "login": {
        "url": "https://accounts.google.com/ServiceLogin?service=cloudconsole",
        "steps": [
          { "fill": "input[type=email], input[name=identifier]", "value": "{{GCP_EMAIL}}" },
          { "click": "#identifierNext button, button:has-text('Next'), button:has-text('Avançar')" },
          { "waitSelector": "input[type=password], input[name=Passwd]", "timeout": 15000 },
          { "fill": "input[type=password], input[name=Passwd]", "value": "{{GCP_PASSWORD}}" },
          { "click": "#passwordNext button, button:has-text('Next'), button:has-text('Avançar')" },
          { "waitSelector": "a[href*='console.cloud.google.com'], iframe, header", "timeout": 30000 }
        ]
      }
    },
    "azure": {
      "envBase": "AZURE_LOGIN_URL",
      "login": {
        "url": "https://portal.azure.com",
        "steps": [
          { "fill": "input[type=email], input[name=loginfmt]", "value": "{{AZURE_EMAIL}}" },
          { "click": "input[type=submit], button:has-text('Next'), button:has-text('Avançar')" },
          { "waitSelector": "input[type=password], input[name=passwd]", "timeout": 20000 },
          { "fill": "input[type=password], input[name=passwd]", "value": "{{AZURE_PASSWORD}}" },
          { "click": "input[type=submit], button:has-text('Sign in'), button:has-text('Entrar')" },
          { "waitSelector": "header, nav, [data-bi-id='Dashboard']", "timeout": 30000 }
        ]
      }
    },
    "openrouter": {
      "envBase": "OPENROUTER_URL",
      "login": {
        "url": "https://openrouter.ai/sign-in",
        "steps": [
          { "fill": "input[type=email], input[name=identifier], input[name=email]", "value": "{{OPENROUTER_EMAIL}}" },
          { "fill": "input[type=password], input[name=password]", "value": "{{OPENROUTER_PASSWORD}}" },
          { "click": "button[type=submit], button:has-text('Sign in'), button:has-text('Continue')" },
          { "waitSelector": "nav, header, a:has-text('Keys')", "timeout": 25000 }
        ]
      }
    },
    "front": {
      "envBase": "FRONT_URL",
      "login": {
        "url": "{{FRONT_URL}}",
        "steps": [
          { "waitSelector": "#usernameInput, input[type=email]", "timeout": 25000 },
          { "fill": "#usernameInput, input[type=email]", "value": "{{FRONT_ADMIN_EMAIL}}" },
          { "fill": "#passwordInput, input[type=password]", "value": "{{FRONT_ADMIN_PASSWORD}}" },
          { "click": "#loginForm button[type=submit], button:has-text('Entrar')" },
          { "waitSelector": "#appContainer:visible, .sidebar, nav, aside", "timeout": 25000 }
        ]
      }
    }
  },

  "globalMasks": [
    "input[readonly]",
    "input[type=password]",
    "input[aria-label*=senha i]",
    "input[aria-label*=password i]",
    "input[aria-label*=email i]",
    "code:has-text('postgres://')",
    "code:has-text('postgresql://')",
    "code:has-text('redis://')",
    "code:has-text('eyJ')"
  ],

  "globalMasksByPage": {
    "_doc": "Aplicado quando page.url() bate com o prefixo. Esconde linhas de outras pastas/clientes na lista do n8n.",
    "longflatworm-n8n.cloudfy.live": [
      "[data-test-id='resources-list-item']:not(:has-text('São Rafael')):not(:has-text('Jornada de IA')):not(:has-text('Personal'))",
      ".folder-card:not(:has-text('São Rafael')):not(:has-text('Jornada de IA'))",
      "a[href*='/workflows/']:has-text('Folder'):not(:has-text('São Rafael'))"
    ]
  },

  "globalRedactPatterns": [
    "longflatworm[A-Za-z0-9-]*",
    "[a-z0-9-]+\\.cloudfy\\.(?:live|space|app)",
    "\\b[a-z0-9]{20}\\.supabase\\.co\\b",
    "eyJ[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}",
    "sk-(?:proj-|or-|ant-)?[A-Za-z0-9_-]{20,}",
    "\\b\\d{2}\\.\\d{3}\\.\\d{3}/\\d{4}-\\d{2}\\b",
    "\\bSR-\\d{6}-\\d{4}\\b",
    "@saorafael\\.com\\.br",
    "istic\\.sp@gmail\\.com",
    "R\\$\\s?[\\d.]+,\\d{2}"
  ],

  "_uiHints": {
    "cloudfy": "Cada serviço tem tabs: Geral / Admin / Database / Configurações. Conteúdo em cards (Admin, Credenciais). Inputs readonly expõem segredos."
  },


        "query": "SELECT \n  session_id, \n  MIN(created_at) as data_inicio,\n  (SELECT message->>'content'\n   FROM saorafael_chat_message sr_cm2 \n   WHERE sr_cm2.session_id = sr_cm.session_id \n   AND sr_cm2.message->>'type' = 'human'\n   ORDER BY id DESC LIMIT 1) as titulo\nFROM saorafael_chat_message sr_cm\nGROUP BY session_id\nORDER BY data_inicio DESC;",
